# 环境变量模板（复制为 .env.development 或 .env.production）
# ──────────────────────────────────────────────
# 开发环境 (.env.development):
#   VITE_API_BASE_URL=/api/v1          （相对路径，通过 Vite 代理转发）
#   VITE_PROXY_TARGET=http://localhost:8080  （后端实际地址）
#
# 生产环境 (.env.production):
#   VITE_API_BASE_URL=https://api.example.com/api/v1  （后端完整地址）
#   （生产环境不需要 VITE_PROXY_TARGET，代理由 Nginx/CDN 处理）
# ──────────────────────────────────────────────
VITE_API_BASE_URL=/api/v1
VITE_PROXY_TARGET=http://localhost:8080
VITE_APP_TITLE=TeamGallery
VITE_ENABLE_MOCK=false

# Sentry 错误上报 DSN（生产环境必填）
# 获取方式：https://sentry.io -> Settings -> Projects -> Client Keys (DSN)
VITE_SENTRY_DSN=
