{
  "name": "teamgalleryui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:style": "stylelint \"src/**/*.{css,vue}\" --fix",
    "lint:style:check": "stylelint \"src/**/*.{css,vue}\"",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "ci": "npm run lint:check && npm run format:check && npm run test:run && npm run build",
    "ci:coverage": "npm run lint:check && npm run format:check && npm run test:coverage && npm run build",
    "prepare": "husky",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "dependencies": {
    "@sentry/browser": "^10.55.0",
    "@sentry/vue": "^10.55.0",
    "axios": "^1.7.9",
    "dompurify": "^3.4.8",
    "element-plus": "^2.14.1",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "vitest run related --passWithNoTests"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
