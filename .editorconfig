# EditorConfig 配置文件
# 详见: https://editorconfig.org

# 顶层配置
root = true

# 默认配置（适用于所有文件）
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript/JavaScript 文件
[*.{ts,js,mjs,cjs}]
indent_size = 2

# Vue 单文件组件
[*.vue]
indent_size = 2

# JSON 文件
[*.json]
indent_size = 2

# Markdown 文件
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# YAML 文件
[*.{yml,yaml}]
indent_size = 2

# CSS/SCSS 文件
[*.{css,scss,sass,less}]
indent_size = 2

# HTML 文件
[*.html]
indent_size = 2

# Shell 脚本
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Git 相关文件
[.gitattributes]
end_of_line = lf

[.gitignore]
end_of_line = lf

# 忽略的文件
[{node_modules,dist,coverage}/**]
indent_style = unset
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
